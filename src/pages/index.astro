---
import { marked } from 'marked';
import '../styles/global.css';
import githubCornerSvg from '../assets/github-corner.svg?raw';
import { Megaphone, MapPin, Calendar } from 'lucide-astro';

const KUBECON_SCHED_URL = 'https://sched.co/2DY82';

const MANIFESTO_URL =
  'https://raw.githubusercontent.com/reverse-gitops/manifesto/main/README.md';

const res = await fetch(MANIFESTO_URL);
if (!res.ok) {
  throw new Error(`Failed to fetch manifesto: ${res.status} ${res.statusText}`);
}
const raw = await res.text();

// Strip the H1 title — rendered in the hero
const body = raw.replace(/^#[^#].*\n/, '').trimStart();

let content = marked.parse(body) as string;

// Promote the closing statement to a pull-quote block
content = content.replace(
  /<p>The API comes first\. Git remembers\.<\/p>\s*<p>That is Reverse GitOps\.<\/p>/,
  `<div class="pull-quote">
    <p class="pull-main">The API comes first.<br>Git remembers.</p>
    <p class="pull-sub">That is Reverse GitOps.</p>
  </div>`
);

// Style the opening hook paragraph
content = content.replace(/<p>(GitOps gave us)/, '<p class="lead">$1');

const apiRes = await fetch('https://api.github.com/repos/reverse-gitops/manifesto');
const repoData = apiRes.ok ? await apiRes.json() : {};
const stars: number = repoData.stargazers_count ?? 0;

const buildDate = new Date().toISOString().slice(0, 10);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reverse GitOps</title>
    <meta
      name="description"
      content="An API-first operating model where users and agents make validated changes through a typed platform API, while a controller writes those changes back into Git."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="https://github.com/reverse-gitops/manifesto" class="github-corner" aria-label="Star us on GitHub" target="_blank" rel="noopener noreferrer" set:html={githubCornerSvg} />

    <div class="hero">
      <div class="hero-glow"></div>
      <div class="hero-inner">
        <div class="wordmark">
          <span class="w-reverse">Reverse</span><svg class="logo-combine" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <defs>
              <linearGradient id="combine-grad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%"   stop-color="#60a5fa" />
                <stop offset="50%"  stop-color="#4493f8" />
                <stop offset="100%" stop-color="#a78bfa" />
              </linearGradient>
            </defs>
            <path d="M17 9 L14 6"                            stroke="#7d8590" />
            <path d="M17 3 L14 6 H19 A2 2 0 0 1 21 8 V10"  stroke="#7d8590" />
            <path d="m7 15 3 3"                              stroke="url(#combine-grad)" />
            <path d="m7 21 3-3H5a2 2 0 0 1-2-2v-2"          stroke="url(#combine-grad)" />
            <rect x="14" y="14" width="7" height="7" rx="1" stroke="url(#combine-grad)" />
            <rect x="3"  y="3"  width="7" height="7" rx="1" stroke="#7d8590" />
          </svg><span class="w-gitops">GitOps</span>
        </div>
        <p class="hero-tagline">API-first. Git-recorded. GitOps-compatible.</p>
        <div class="hero-actions">
          <a href="#manifesto" class="hero-cta">Read the manifesto ↓</a>
          <a href="https://github.com/reverse-gitops/manifesto" class="star-badge" target="_blank" rel="noopener noreferrer">
            <svg class="star-icon" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
            Star on GitHub
            <span class="star-count">{stars}</span>
          </a>
        </div>
      </div>
    </div>

    <a href={KUBECON_SCHED_URL} class="kubecon-banner" target="_blank" rel="noopener noreferrer">
      <Megaphone class="banner-icon" size={16} />
      <span class="banner-sep">·</span>
      <span class="banner-flash">LIVE</span>
      <span class="banner-sep">·</span>
      <span><span id="speaking-verb">I'm speaking</span> at <strong>KubeCon Co-located 2026</strong></span>
      <span class="banner-sep">·</span>
      <MapPin class="banner-icon" size={14} />
      <span>Amsterdam</span>
      <span class="banner-sep">·</span>
      <Calendar class="banner-icon" size={14} />
      <span>March 23, 2026</span>
    </a>

    <script>
      // Talk: Monday March 23, 2026 15:55–16:20 CET (UTC+1)
      const talkStart = new Date('2026-03-23T15:55:00+01:00');
      const talkEnd   = new Date('2026-03-23T16:20:00+01:00');
      const now = new Date();
      const el = document.getElementById('speaking-verb');
      if (el) {
        if (now >= talkStart && now < talkEnd) {
          el.textContent = "I'm currently speaking";
        } else if (now >= talkEnd) {
          el.textContent = "I've spoken";
        }
        // before the talk: default "I'm speaking" stays
      }
    </script>

    <main id="manifesto">
      <article class="manifesto" set:html={content} />
    </main>

    <footer>
      <p>
        Content from <a
          href="https://github.com/reverse-gitops/manifesto"
          target="_blank"
          rel="noopener noreferrer">reverse-gitops/manifesto</a
        > &mdash; built {buildDate}
      </p>
    </footer>

  </body>
</html>
